{
  "openapi": "3.1.0",
  "info": {
    "title": "Kasdex API",
    "description": "Local-first Kaspa indexer and dashboard API",
    "license": {
      "name": "MIT",
      "identifier": "MIT"
    },
    "version": "0.1.0"
  },
  "paths": {
    "/api/v1/blocks": {
      "get": {
        "tags": [
          "blocks"
        ],
        "operationId": "listBlocks",
        "parameters": [
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "maximum": 100,
              "minimum": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated block summaries",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Page"
                }
              }
            }
          },
          "400": {
            "description": "Invalid pagination query",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/blocks/{hash}": {
      "get": {
        "tags": [
          "blocks"
        ],
        "operationId": "getBlock",
        "parameters": [
          {
            "name": "hash",
            "in": "path",
            "description": "32-byte block hash as hex",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Block detail",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BlockDetail"
                }
              }
            }
          },
          "400": {
            "description": "Invalid hash",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "404": {
            "description": "Block not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/health": {
      "get": {
        "tags": [
          "system"
        ],
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "Service health",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/indexer/status": {
      "get": {
        "tags": [
          "system"
        ],
        "operationId": "getIndexerStatus",
        "responses": {
          "200": {
            "description": "Indexer status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IndexerStatusResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/search": {
      "get": {
        "tags": [
          "search"
        ],
        "operationId": "search",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid search query",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/transactions/{txid}": {
      "get": {
        "tags": [
          "transactions"
        ],
        "operationId": "getTransaction",
        "parameters": [
          {
            "name": "txid",
            "in": "path",
            "description": "32-byte transaction id as hex",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Transaction summary",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransactionSummary"
                }
              }
            }
          },
          "400": {
            "description": "Invalid transaction id",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "404": {
            "description": "Transaction not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApiError": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "request_id": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "BlockDetail": {
        "type": "object",
        "required": [
          "hash",
          "blue_score",
          "daa_score",
          "tx_count",
          "timestamp"
        ],
        "properties": {
          "blue_score": {
            "type": "string"
          },
          "daa_score": {
            "type": "string"
          },
          "hash": {
            "type": "string"
          },
          "timestamp": {
            "type": "string"
          },
          "tx_count": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          }
        }
      },
      "BlockSummary": {
        "type": "object",
        "required": [
          "hash",
          "blue_score",
          "daa_score",
          "tx_count",
          "timestamp"
        ],
        "properties": {
          "blue_score": {
            "type": "string"
          },
          "daa_score": {
            "type": "string"
          },
          "hash": {
            "type": "string"
          },
          "timestamp": {
            "type": "string"
          },
          "tx_count": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          }
        }
      },
      "CoverageRange": {
        "type": "object",
        "required": [
          "range_id",
          "start_hash",
          "end_hash",
          "end_daa_score",
          "source",
          "coverage_class"
        ],
        "properties": {
          "coverage_class": {
            "type": "string"
          },
          "end_daa_score": {
            "type": "string"
          },
          "end_hash": {
            "type": "string"
          },
          "range_id": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "start_daa_score": {
            "type": [
              "string",
              "null"
            ]
          },
          "start_hash": {
            "type": "string"
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "required": [
          "status",
          "version"
        ],
        "properties": {
          "status": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        }
      },
      "IndexedContext": {
        "type": "object",
        "required": [
          "network",
          "is_synced",
          "source"
        ],
        "properties": {
          "indexed_score": {
            "type": [
              "string",
              "null"
            ]
          },
          "is_synced": {
            "type": "boolean"
          },
          "network": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "virtual_daa_score": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "IndexerStatusResponse": {
        "type": "object",
        "required": [
          "state",
          "network",
          "source",
          "coverage_evaluation"
        ],
        "properties": {
          "coverage": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/CoverageRange"
              }
            ]
          },
          "coverage_evaluation": {
            "type": "string"
          },
          "indexed_block_hash": {
            "type": [
              "string",
              "null"
            ]
          },
          "indexed_score": {
            "type": [
              "string",
              "null"
            ]
          },
          "lag_blocks": {
            "type": [
              "string",
              "null"
            ]
          },
          "lag_daa_score": {
            "type": [
              "string",
              "null"
            ]
          },
          "last_blocks_per_second": {
            "type": [
              "number",
              "null"
            ],
            "format": "double"
          },
          "last_checkpoint_hash": {
            "type": [
              "string",
              "null"
            ]
          },
          "last_error": {
            "type": [
              "string",
              "null"
            ]
          },
          "last_error_at": {
            "type": [
              "string",
              "null"
            ]
          },
          "last_indexed_blocks": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "minimum": 0
          },
          "last_indexed_transactions": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "minimum": 0
          },
          "last_poll_duration_ms": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "minimum": 0
          },
          "last_poll_finished_at": {
            "type": [
              "string",
              "null"
            ]
          },
          "last_poll_started_at": {
            "type": [
              "string",
              "null"
            ]
          },
          "last_start_hash": {
            "type": [
              "string",
              "null"
            ]
          },
          "last_success_at": {
            "type": [
              "string",
              "null"
            ]
          },
          "last_transactions_per_second": {
            "type": [
              "number",
              "null"
            ],
            "format": "double"
          },
          "network": {
            "type": "string"
          },
          "node_observed_at": {
            "type": [
              "string",
              "null"
            ]
          },
          "source": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "virtual_daa_score": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "Page": {
        "type": "object",
        "required": [
          "items",
          "indexed_context"
        ],
        "properties": {
          "indexed_context": {
            "$ref": "#/components/schemas/IndexedContext"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BlockSummary"
            }
          },
          "next_cursor": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "SearchResponse": {
        "type": "object",
        "required": [
          "query"
        ],
        "properties": {
          "query": {
            "type": "string"
          },
          "result": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/SearchResult"
              }
            ]
          }
        }
      },
      "SearchResult": {
        "oneOf": [
          {
            "type": "object",
            "required": [
              "address",
              "kind"
            ],
            "properties": {
              "address": {
                "type": "string"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "address"
                ]
              }
            }
          },
          {
            "type": "object",
            "required": [
              "hash",
              "kind"
            ],
            "properties": {
              "hash": {
                "type": "string"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "block"
                ]
              }
            }
          },
          {
            "type": "object",
            "required": [
              "txid",
              "kind"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "transaction"
                ]
              },
              "txid": {
                "type": "string"
              }
            }
          }
        ]
      },
      "TransactionDetail": {
        "type": "object",
        "required": [
          "accepting_daa_score",
          "accepting_timestamp",
          "version",
          "lock_time",
          "subnetwork_id",
          "gas",
          "payload_size",
          "mass",
          "storage_mass",
          "compute_mass",
          "block_time",
          "inputs",
          "outputs"
        ],
        "properties": {
          "accepting_daa_score": {
            "type": "string"
          },
          "accepting_timestamp": {
            "type": "string"
          },
          "block_time": {
            "type": "string"
          },
          "compute_mass": {
            "type": "string"
          },
          "gas": {
            "type": "string"
          },
          "inputs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TransactionInput"
            }
          },
          "lock_time": {
            "type": "string"
          },
          "mass": {
            "type": "string"
          },
          "outputs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TransactionOutput"
            }
          },
          "payload_size": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "storage_mass": {
            "type": "string"
          },
          "subnetwork_id": {
            "type": "string"
          },
          "version": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          }
        }
      },
      "TransactionInput": {
        "type": "object",
        "required": [
          "sequence",
          "sig_op_count",
          "compute_budget",
          "previous_output_resolved"
        ],
        "properties": {
          "compute_budget": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "previous_output_index": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int32",
            "minimum": 0
          },
          "previous_output_resolved": {
            "type": "boolean"
          },
          "previous_txid": {
            "type": [
              "string",
              "null"
            ]
          },
          "sequence": {
            "type": "string"
          },
          "sig_op_count": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          }
        }
      },
      "TransactionOutput": {
        "type": "object",
        "required": [
          "output_index",
          "amount",
          "script_public_key_version"
        ],
        "properties": {
          "amount": {
            "type": "string"
          },
          "output_index": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "script_public_key_address": {
            "type": [
              "string",
              "null"
            ]
          },
          "script_public_key_type": {
            "type": [
              "string",
              "null"
            ]
          },
          "script_public_key_version": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          }
        }
      },
      "TransactionSummary": {
        "type": "object",
        "required": [
          "txid",
          "input_count",
          "output_count",
          "detail_available",
          "detail_complete"
        ],
        "properties": {
          "accepting_block_hash": {
            "type": [
              "string",
              "null"
            ]
          },
          "detail": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/TransactionDetail"
              }
            ]
          },
          "detail_available": {
            "type": "boolean"
          },
          "detail_complete": {
            "type": "boolean"
          },
          "input_count": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "output_count": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "txid": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "system",
      "description": "System and indexer status"
    },
    {
      "name": "blocks",
      "description": "Block queries"
    },
    {
      "name": "search",
      "description": "Search"
    }
  ]
}